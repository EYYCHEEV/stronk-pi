#!/usr/bin/env python3
from __future__ import annotations

import os
import runpy
from pathlib import Path


def main() -> None:
    repo_root = Path(__file__).resolve().parents[1]
    os.environ.setdefault("STRONKPI_SETUP_ROOT", str(repo_root))
    runpy.run_path(str(repo_root / "lib" / "stronk-pi-guard.py"), run_name="__main__")


if __name__ == "__main__":
    main()
